  <VisualUpdateConfiguration isPackaged="false">
    <ProductName>&lt;AppName&gt;</ProductName>
    <ProductVersion>&lt;AppVersion&gt;</ProductVersion>
    <Language>0</Language>
    <UpdateScriptURIs>

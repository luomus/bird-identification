    </InstallationFiles>
    <Languages/>
    <Variables>
      <Variable name="UserLocalAppData" rootKey="HKEY_CURRENT_USER" subKey="Volatile Environment" valueName="LOCALAPPDATA" defaultValue="&lt;AppData&gt;\..\Local"/>
    </Variables>
    <Commands/>
    <Registry/>
    <Shortcuts defaultPath="&lt;Company&gt;\&lt;AppName&gt;\" isDefaultPathAlterable="false" isCreateStartmenuShortcutsForAllUsers="false" isCreateDesktopShortcutsForAllUsers="false">
      <Shortcut destination="Startmenu" name="Bird Identifier" targetFile="&lt;InstallPath&gt;\birdIdentifier.exe" commandLineArguments="" iconFilePath="" iconIndex="0"/>
      <Shortcut destination="Desktop" name="Bird Identifier" targetFile="&lt;InstallPath&gt;\birdIdentifier.exe" commandLineArguments="" iconFilePath="" iconIndex="0"/>
    </Shortcuts>
    <Serials isDialogEnabled="false" count="1000" mask ="#####-#####-#####-#####"/>
    <SplashScreen isDialogEnabled="false" delayTime="2">
      <Image filePath=""/>
      <Sound isEnabled="false" filePath=""/>
    </SplashScreen>
    <License isDialogEnabled="false">

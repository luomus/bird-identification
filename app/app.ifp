<?xml version="1.0" encoding="UTF-8"?>

<InstallForgeProject>
  <Metadata productVersion="1.5.0" projectFileVersion="2.0"/>
  <ProductInformation>
    <Name>Bird Identifier</Name>
    <Version>0.1.0</Version>
    <CompanyName>Luomus</CompanyName>
    <WebURI>https://laji.fi</WebURI>
  </ProductInformation>
  <InstallerConfiguration>
    <Prerequisites>
      <OperatingSystem check="true">
        <WindowsXP>false</WindowsXP>
        <WindowsServer2003>false</WindowsServer2003>
        <WindowsVista>false</WindowsVista>
        <WindowsServer2008>false</WindowsServer2008>
        <Windows7>true</Windows7>
